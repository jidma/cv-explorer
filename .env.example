# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5436/cv_explorer

# LLM Provider: "openai" or "anthropic"
LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=sk-...

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Server
PORT=3035

# Embedding model dimension (1536 for OpenAI text-embedding-3-small, 1024 for Anthropic)
EMBEDDING_DIMENSION=1536
